<%- include('../partials/header', { title: 'Evaluation Periods' }) %>
<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'periods' }) %>
  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Evaluation Periods' }) %>
    <div class="content-area">

      <div class="flex justify-between items-center" style="margin-bottom:1.25rem">
        <div>
          <p class="text-muted text-sm">
            Control when students can submit evaluations.
            Only courses assigned to a period will appear on student evaluation forms.
          </p>
        </div>
        <a href="/admin/periods/new" class="btn btn-primary">+ New Period</a>
      </div>

      <% if(successMsg != null){ %>
        <div class="alert alert-success" style="margin-bottom:1rem" data-autodismiss="5000">✓ <%=successMsg%></div>
      <% } %>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Title</th><th>Semester</th><th>Start</th><th>End</th>
              <th>Courses</th><th>Status</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
          <% if(periods.length===0){ %>
            <tr><td colspan="7">
              <div class="empty-state" style="padding:3rem">
                <div class="empty-icon">📅</div>
                <h3>No evaluation periods yet</h3>
                <p>Create your first evaluation window to allow students to submit responses.</p>
                <a href="/admin/periods/new" class="btn btn-primary" style="margin-top:1rem">+ Create First Period</a>
              </div>
            </td></tr>
          <% } else { %>
            <% periods.forEach((p,idx)=>{ %>
              <%
                const now=new Date(), start=new Date(p.startDate), end=new Date(p.endDate);
                const isOpen=p.isActive&&now>=start&&now<=end;
                const isPast=now>end;
                const isFuture=now<start;
                const statusLabel=isOpen?'🟢 Open':isPast?'Closed':isFuture?'⏳ Upcoming':'Inactive';
                const statusBadge=isOpen?'badge-green':isPast?'badge-gray':isFuture?'badge-yellow':'badge-red';
                const fmt=d=>new Date(d).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'});
                const daysLeft=isOpen?Math.ceil((end-now)/(1000*60*60*24)):null;
              %>
              <tr style="animation:fadeUp 0.25s ease both;animation-delay:<%=idx*0.03%>s">
                <td>
                  <div style="font-weight:700;font-size:0.9rem"><%=p.title%></div>
                  <div style="font-size:0.75rem;color:var(--text-muted)"><%=p.academicYear%></div>
                </td>
                <td><span class="badge badge-blue"><%=p.semester%> Sem</span></td>
                <td style="font-size:0.82rem;white-space:nowrap"><%=fmt(p.startDate)%></td>
                <td style="font-size:0.82rem;white-space:nowrap">
                  <%=fmt(p.endDate)%>
                  <% if(daysLeft!==null){ %>
                    <div style="font-size:0.7rem;color:<%=daysLeft<=3?'var(--danger)':daysLeft<=7?'var(--warning)':'var(--success)'%>;font-weight:700">
                      <%=daysLeft%>d left
                    </div>
                  <% } %>
                </td>
                <td>
                  <span style="font-weight:700"><%=p.courses?p.courses.length:0%></span>
                  <span class="text-muted text-xs"> course<%=(p.courses&&p.courses.length!==1)?'s':''%></span>
                </td>
                <td><span class="badge <%=statusBadge%>"><%=statusLabel%></span></td>
                <td>
                  <div class="flex gap-1">
                    <a href="/admin/periods/<%=p._id%>/edit" class="btn btn-secondary btn-sm">✏ Edit</a>
                    <form action="/admin/periods/<%=p._id%>/toggle" method="POST" style="margin:0">
                      <button type="submit" class="btn btn-ghost btn-sm"
                              data-confirm="<%=p.isActive?'Deactivate this period?':'Activate this period?'%>"
                              data-tooltip="<%=p.isActive?'Deactivate':'Activate'%>">
                        <%=p.isActive?'🔒':'🔓'%>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </main>
</div>
<%- include('../partials/footer') %>

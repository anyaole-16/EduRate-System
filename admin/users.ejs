<%- include('../partials/header', { title: 'User Management' }) %>
<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'users' }) %>
  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'User Management' }) %>
    <div class="content-area">

      <div class="card" style="margin-bottom:1.25rem">
        <div class="flex gap-2" style="flex-wrap:wrap;align-items:flex-end;justify-content:space-between">
          <form action="/admin/users" method="GET" class="flex gap-2" style="flex-wrap:wrap;align-items:flex-end">
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label">Role</label>
              <select name="role" class="form-control" style="width:160px; max-width:100%">
                <option value="">All Roles</option>
                <option value="student"  <%= filterRole === 'student'  ? 'selected' : '' %>>Students</option>
                <option value="lecturer" <%= filterRole === 'lecturer' ? 'selected' : '' %>>Lecturers</option>
                <option value="admin"    <%= filterRole === 'admin'    ? 'selected' : '' %>>Admins</option>
              </select>
            </div>
            <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
          </form>
          <div class="flex gap-2" style="align-items:center;flex-wrap:wrap">
            <input type="search" data-search-target="users-table" class="form-control"
                   placeholder="Search by name or email…" style="width:210px; max-width:100%; font-size:0.82rem">
            <form action="/admin/users/advance-levels" method="POST" style="margin:0">
              <button type="submit" class="btn btn-secondary" data-confirm="This will advance all student levels (100→200, etc.). Continue?">Advance Levels</button>
            </form>
            <a href="/admin/users/new" class="btn btn-primary">+ Add User</a>
          </div>
        </div>
      </div>

      <% if (successMsg != null) { %>
        <div class="alert alert-success" style="margin-bottom:1rem" data-autodismiss="5000">✓ <%= successMsg %></div>
      <% } %>

      <div class="table-wrapper">
        <table id="users-table">
          <thead>
            <tr>
              <th>User</th><th>Role</th><th>Department</th><th>Level</th>
              <th>ID / Matric</th><th>Joined</th><th>Status</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
          <% if(users.length===0){ %>
            <tr><td colspan="8">
              <div class="empty-state" style="padding:3rem">
                <div class="empty-icon">👥</div>
                <h3>No users found</h3>
                <p>Try a different role filter or <a href="/admin/users/new">add a new user</a>.</p>
              </div>
            </td></tr>
          <% } else { %>
            <% users.forEach((u,idx)=>{ %>
              <%
                const rac={admin:'avatar-gold',lecturer:'avatar-green',student:'avatar-blue'};
                const rbc={admin:'badge-yellow',lecturer:'badge-green',student:'badge-blue'};
                const ini=u.fullName.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
              %>
              <tr style="animation:fadeUp 0.25s ease both;animation-delay:<%=idx*0.03%>s">
                <td>
                  <div class="flex items-center gap-1">
                    <div class="avatar <%=rac[u.role]||'avatar-blue'%>" style="width:34px;height:34px;font-size:0.78rem;flex-shrink:0">
                      <%=ini%>
                    </div>
                    <div>
                      <div style="font-weight:600;font-size:0.875rem"><%=u.fullName%></div>
                      <div style="font-size:0.75rem;color:var(--text-muted)"><%=u.email%></div>
                    </div>
                  </div>
                </td>
                <td><span class="badge <%=rbc[u.role]||'badge-gray'%>"><%=u.role%></span></td>
                <td style="font-size:0.875rem"><%=u.department||'—'%></td>
                <td style="font-size:0.875rem"><%=u.role === 'student' ? (u.level ? u.level + ' Level' : '—') : '—'%></td>
                <td style="font-family:monospace;font-size:0.8rem;color:var(--text-muted)"><%=u.matricNumber||u.staffId||'—'%></td>
                <td style="font-size:0.82rem;white-space:nowrap">
                  <%=new Date(u.createdAt).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})%>
                </td>
                <td><span class="badge <%=u.isActive?'badge-green':'badge-red'%>"><%=u.isActive?'● Active':'○ Inactive'%></span></td>
                <td>
                  <div class="flex gap-1">
                    <a href="/admin/users/<%=u._id%>/edit" class="btn btn-secondary btn-sm" data-tooltip="Edit">✏ Edit</a>
                    <form action="/admin/users/<%=u._id%>/toggle" method="POST" style="margin:0">
                      <button type="submit" class="btn btn-ghost btn-sm"
                              data-confirm="<%=u.isActive?'Deactivate this user?':'Reactivate this user?'%>">
                        <%=u.isActive?'🔒':'🔓'%>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
            <tr data-empty-row style="display:none">
              <td colspan="8" style="text-align:center;color:var(--text-muted);padding:2.5rem">No users match your search.</td>
            </tr>
          <% } %>
          </tbody>
        </table>
      </div>

      <% if(totalPages != null>1){ %>
        <% const rqs=(filterRole != null)?'&role='+filterRole:''; %>
        <div class="flex items-center justify-between" style="margin-top:1.25rem;font-size:0.85rem;color:var(--text-muted)">
          <span>Page <strong><%=currentPage%></strong> of <strong><%=totalPages%></strong> &nbsp;·&nbsp; <%=totalCount%> users</span>
          <div class="flex gap-1">
            <% if(currentPage>1){ %><a href="?page=<%=currentPage-1%><%=rqs%>" class="btn btn-secondary btn-sm">← Prev</a><% } %>
            <% if(currentPage<totalPages){ %><a href="?page=<%=currentPage+1%><%=rqs%>" class="btn btn-secondary btn-sm">Next →</a><% } %>
          </div>
        </div>
      <% } %>

    </div>
  </main>
</div>
<%- include('../partials/footer') %>

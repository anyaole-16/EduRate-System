<%- include('../partials/header', { title: 'Analytics & Reports' }) %>
<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'analytics' }) %>
  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Analytics & Reports' }) %>
    <div class="content-area">

      <%
        function scoreCol(v){ return v>=4.5?'#0fb981':v>=3.5?'#2a6fdb':v>=2.5?'#f0a847':'#f04a4a'; }
        function scoreLabel(v){ return v>=4.5?'Excellent':v>=3.5?'Good':v>=2.5?'Average':'Below Average'; }
        function scoreBadge(v){ return v>=4.5?'badge-green':v>=3.5?'badge-blue':v>=2.5?'badge-yellow':'badge-red'; }
      %>

      <div class="section-banner" style="margin-bottom:1.75rem">
        <div class="section-banner-icon">📊</div>
        <div>
          <h2>Analytics &amp; Reports</h2>
          <p>Institution-wide evaluation results. Filter by semester, year, or department. Export to CSV or PDF.</p>
        </div>
      </div>

      <!-- FILTER + EXPORT -->
      <div class="card" style="margin-bottom:1.5rem">
        <div class="card-header" style="margin-bottom:1rem">
          <div class="card-title">Filters &amp; Export</div>
          <% if(filters != null && (filters.semester||filters.academicYear||filters.department)){ %>
            <div class="flex items-center gap-1">
              <span class="badge badge-yellow">Active filter</span>
              <a href="/admin/analytics" class="btn btn-ghost btn-sm">✕ Clear</a>
            </div>
          <% } %>
        </div>
        <%
          const qs=[];
          if(filters != null){
            if(filters.semester)     qs.push('semester='+encodeURIComponent(filters.semester));
            if(filters.academicYear) qs.push('academicYear='+encodeURIComponent(filters.academicYear));
            if(filters.department)   qs.push('department='+encodeURIComponent(filters.department));
          }
          const exportQs=qs.length?'?'+qs.join('&'):'';
        %>
        <form action="/admin/analytics" method="GET"
              class="flex gap-2" style="flex-wrap:wrap;align-items:flex-end" data-loading-text="Filtering…">
          <div class="form-group" style="margin-bottom:0;flex:1;min-width:130px">
            <label class="form-label">Semester</label>
            <select name="semester" class="form-control">
              <option value="">All Semesters</option>
              <option value="First"  <%=filters != null && filters.semester==='First'  ?'selected':''%>>First</option>
              <option value="Second" <%=filters != null && filters.semester==='Second' ?'selected':''%>>Second</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:0;flex:1;min-width:140px">
            <label class="form-label">Academic Year</label>
            <input type="text" name="academicYear" class="form-control" placeholder="2023/2024"
                   value="<%=filters != null ? filters.academicYear||'':''%>">
          </div>
          <div class="form-group" style="margin-bottom:0;flex:2;min-width:160px">
            <label class="form-label">Department</label>
            <input type="text" name="department" class="form-control" placeholder="Filter by department"
                   value="<%=filters != null ? filters.department||'':''%>">
          </div>
          <div class="flex gap-1" style="flex-wrap:wrap">
            <button type="submit" class="btn btn-primary">🔍 Apply</button>
            <a href="/admin/analytics" class="btn btn-secondary">Clear</a>
            <a href="/admin/export/csv<%=exportQs%>" class="btn btn-secondary" target="_blank"
               data-tooltip="Download filtered data as CSV">⬇ CSV</a>
            <a href="/admin/export/pdf<%=exportQs%>" class="btn btn-secondary" target="_blank"
               data-tooltip="Generate printable PDF report">📄 PDF</a>
          </div>
        </form>
      </div>

      <% if(!lecturers||lecturers.length===0){ %>
        <div class="card" style="padding:4rem;text-align:center">
          <div style="font-size:3rem;margin-bottom:1rem;opacity:0.3">📊</div>
          <h3 style="margin-bottom:0.5rem">No evaluation data</h3>
          <p class="text-muted text-sm">No evaluations match the selected filters.</p>
          <a href="/admin/analytics" class="btn btn-secondary" style="margin-top:1.25rem">Clear Filters</a>
        </div>
      <% } else { %>

        <!-- SUMMARY STRIP -->
        <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:1.5rem">
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(42,111,219,0.15);color:var(--accent2)">👨‍🏫</div>
            <div class="stat-info"><div class="value"><%=lecturers.length%></div><div class="label">Lecturers Evaluated</div></div>
          </div>
          <%
            const totalResp=lecturers.reduce((s,l)=>s+l.totalResponses,0);
            const allMeans=lecturers.map(l=>l.mean);
            const instAvg=allMeans.length?(allMeans.reduce((a,b)=>a+b,0)/allMeans.length).toFixed(2):'—';
            const instTop=lecturers.slice().sort((a,b)=>b.mean-a.mean)[0];
          %>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(240,168,71,0.15);color:var(--warning)">📝</div>
            <div class="stat-info"><div class="value"><%=totalResp%></div><div class="label">Total Responses</div></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(15,185,129,0.15);color:var(--success)">⭐</div>
            <div class="stat-info">
              <div class="value" style="color:<%=scoreCol(parseFloat(instAvg))%>"><%=instAvg%></div>
              <div class="label">Institution Avg</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(240,168,71,0.15);color:#f59e0b">🥇</div>
            <div class="stat-info">
              <div class="value text-sm" style="font-size:0.875rem;letter-spacing:0;color:var(--success)">
                <%=instTop?instTop.name.split(' ')[0]:'—'%>
              </div>
              <div class="label">Top Lecturer</div>
            </div>
          </div>
        </div>

        <!-- DEPT CHART -->
        <% if(departmentStats&&departmentStats.length>0){ %>
          <div class="card" style="margin-bottom:1.5rem">
            <div class="card-header">
              <div>
                <div class="card-title">Department Average Scores</div>
                <div class="card-subtitle">Mean evaluation score per department — colour indicates performance band</div>
              </div>
              <span class="badge badge-blue"><%=departmentStats.length%> dept<%=departmentStats.length!==1?'s':''%></span>
            </div>
            <div class="chart-container" style="height:<%=departmentStats.length>6?Math.min(departmentStats.length*42,380):260%>px">
              <canvas id="deptChart" aria-label="Department average scores bar chart"></canvas>
            </div>
          </div>
        <% } %>

        <!-- LEADERBOARD -->
        <div class="card" style="margin-bottom:1.5rem">
          <div class="card-header">
            <div>
              <div class="card-title">Lecturer Performance Leaderboard</div>
              <div class="card-subtitle">Ranked by mean evaluation score across all criteria</div>
            </div>
            <div class="flex items-center gap-1">
              <input type="search" data-search-target="leaderboard-table"
                     class="form-control" placeholder="Search lecturers…"
                     style="width:190px;font-size:0.8rem">
              <span class="badge badge-blue"><%=lecturers.length%></span>
            </div>
          </div>

          <!-- Desktop table view -->
          <div class="table-wrapper">
            <table id="leaderboard-table">
              <thead>
                <tr>
                  <th style="width:40px">Rank</th>
                  <th>Lecturer</th>
                  <th>Department</th>
                  <th style="min-width:160px">Mean Score</th>
                  <th>Responses</th>
                  <th>Rating</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% const sorted=lecturers.slice().sort((a,b)=>b.mean-a.mean); %>
                <% sorted.forEach((l,i)=>{ %>
                  <%
                    const c=scoreCol(l.mean);
                    const medal=i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1);
                    const medalColor=i===0?'#f0a847':i===1?'#94a3b8':i===2?'#d97706':'var(--text-dim)';
                  %>
                  <tr style="animation:fadeUp 0.25s ease both;animation-delay:<%=i*0.025%>s">
                    <td style="text-align:center;font-weight:800;font-size:<%=i<3?'1.1rem':'0.85rem'%>;color:<%=medalColor%>">
                      <%=medal%>
                    </td>
                    <td>
                      <div style="font-weight:700;font-size:0.9rem"><%=l.name%></div>
                      <div style="font-size:0.75rem;color:var(--text-muted)">
                        <%=(l.courses||[]).join(', ')||'—'%>
                      </div>
                    </td>
                    <td style="font-size:0.875rem"><%=l.department||'—'%></td>
                    <td>
                      <div class="flex items-center gap-1">
                        <div class="progress-bar" style="width:90px;flex-shrink:0">
                          <div class="progress-fill" style="width:<%=((l.mean/5)*100).toFixed(0)%>%;background:<%=c%>"></div>
                        </div>
                        <span style="color:<%=c%>;font-weight:800;min-width:34px"><%=l.mean.toFixed(2)%></span>
                      </div>
                    </td>
                    <td style="font-size:0.875rem"><%=l.totalResponses%></td>
                    <td><span class="badge <%=scoreBadge(l.mean)%>"><%=scoreLabel(l.mean)%></span></td>
                    <td>
                      <a href="/admin/analytics/lecturer/<%=l._id%>"
                         class="btn btn-ghost btn-sm" data-tooltip="View full report">→</a>
                    </td>
                  </tr>
                <% }) %>
                <tr data-empty-row style="display:none">
                  <td colspan="7" style="text-align:center;color:var(--text-muted);padding:2rem">No lecturers match your search.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

      <% } %>
    </div>
  </main>
</div>

<% if(departmentStats != null && departmentStats.length > 0){ %>
<script>
  window.EDURATE_CHARTS = {
    dept: {
      labels: <%- JSON.stringify(departmentStats.map(d=>d.department)) %>,
      data:   <%- JSON.stringify(departmentStats.map(d=>d.avgScore)) %>,
      colors: <%- JSON.stringify(departmentStats.map(d=>
        d.avgScore>=4.5?'#0fb981':d.avgScore>=3.5?'#2a6fdb':d.avgScore>=2.5?'#f0a847':'#f04a4a'
      )) %>,
    }
  };
</script>
<% } %>

<%- include('../partials/footer', { extraJs: ['charts.js'] }) %>

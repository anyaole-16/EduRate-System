<%- include('../partials/header', { title: lecturer.fullName + ' — Report' }) %>
<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'analytics' }) %>
  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Lecturer Report' }) %>
    <div class="content-area">

      <%
        function scoreCol(v){ return v>=4.5?'#0fb981':v>=3.5?'#2a6fdb':v>=2.5?'#f0a847':'#f04a4a'; }
        function scoreLabel(v){ return v>=4.5?'Excellent':v>=3.5?'Good':v>=2.5?'Average':'Below Average'; }
        function scoreBadge(v){ return v>=4.5?'badge-green':v>=3.5?'badge-blue':v>=2.5?'badge-yellow':'badge-red'; }
      %>

      <!-- BACK + EXPORT -->
      <div class="flex items-center gap-1" style="margin-bottom:1.5rem;flex-wrap:wrap">
        <a href="/admin/analytics" class="btn btn-secondary btn-sm">← Back to Analytics</a>
        <a href="/admin/export/pdf?lecturerId=<%=lecturer._id%>"
           class="btn btn-secondary btn-sm" target="_blank"
           data-tooltip="Generate printable PDF report for this lecturer">📄 PDF Report</a>
        <a href="/admin/export/csv?lecturerId=<%=lecturer._id%>"
           class="btn btn-secondary btn-sm"
           data-tooltip="Download evaluation data as CSV">⬇ CSV Export</a>
      </div>

      <!-- LECTURER HEADER -->
      <div class="card" style="margin-bottom:1.5rem;border-left:3px solid var(--accent)">
        <div class="flex items-center gap-3" style="flex-wrap:wrap">
          <div class="avatar-lg avatar-green" style="flex-shrink:0">
            <%=lecturer.fullName.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2)%>
          </div>
          <div style="flex:1">
            <h2 style="font-size:1.2rem;margin-bottom:0.2rem"><%=lecturer.fullName%></h2>
            <p class="text-muted text-sm">
              <%=lecturer.department||'—'%>
              <% if(lecturer.school){ %> &nbsp;·&nbsp; <%=lecturer.school%> <% } %>
              <% if(lecturer.email){ %> &nbsp;·&nbsp; <%=lecturer.email%> <% } %>
            </p>
          </div>
          <div class="flex gap-2" style="flex-shrink:0">
            <div style="text-align:center;padding:0.75rem 1.25rem;background:var(--surface2);border-radius:var(--radius-sm)">
              <div style="font-size:1.5rem;font-weight:800;color:var(--accent2)"><%=totalResponses%></div>
              <div class="text-xs text-muted">Responses</div>
            </div>
            <% if(overallStats){ %>
              <%
                const ringColor=scoreCol(overallStats.mean);
                const r=40, circ=+(2*Math.PI*r).toFixed(2), dash=+((overallStats.mean/5)*circ).toFixed(2);
              %>
              <div style="text-align:center;padding:0.75rem 1.25rem;background:var(--surface2);border-radius:var(--radius-sm)">
                <div style="font-size:1.5rem;font-weight:800;color:<%=ringColor%>"><%=overallStats.mean.toFixed(2)%></div>
                <div class="text-xs text-muted"><%=scoreLabel(overallStats.mean)%></div>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <% if(totalResponses===0){ %>
        <div class="card" style="padding:4rem;text-align:center">
          <div style="font-size:3rem;margin-bottom:1rem;opacity:0.3">📊</div>
          <h3 style="margin-bottom:0.5rem">No evaluations found</h3>
          <p class="text-muted text-sm">No evaluation data for this lecturer under the current filter.</p>
        </div>
      <% } else { %>

        <!-- STAT STRIP -->
        <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:1.5rem">
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(42,111,219,0.15);color:var(--accent2)">📬</div>
            <div class="stat-info"><div class="value"><%=totalResponses%></div><div class="label">Responses</div></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(15,185,129,0.15);color:var(--success)">📐</div>
            <div class="stat-info">
              <div class="value" style="color:<%=overallStats?scoreCol(overallStats.mean):'inherit'%>">
                <%=overallStats?overallStats.mean.toFixed(2):'—'%>
              </div>
              <div class="label">Mean Score</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(139,92,246,0.15);color:#c4b5fd">📏</div>
            <div class="stat-info"><div class="value"><%=overallStats?overallStats.median:'—'%></div><div class="label">Median</div></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background:rgba(240,168,71,0.15);color:var(--warning)">🎯</div>
            <div class="stat-info"><div class="value"><%=overallStats?overallStats.mode:'—'%></div><div class="label">Mode</div></div>
          </div>
        </div>

        <!-- CRITERIA TABLE -->
        <div class="card" style="margin-bottom:1.5rem">
          <div class="card-header">
            <div>
              <div class="card-title">Criteria Breakdown</div>
              <div class="card-subtitle">Statistical summary per criterion — sorted by score descending</div>
            </div>
            <span class="badge badge-blue"><%=criteriaStats.length%> criteria</span>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Criteria</th><th style="min-width:160px">Mean Score</th>
                  <th>Median</th><th>Mode</th><th>Responses</th><th>Rating</th>
                </tr>
              </thead>
              <tbody>
                <% criteriaStats.slice().sort((a,b)=>b.mean-a.mean).forEach((s,idx)=>{ %>
                  <% const c=scoreCol(s.mean); %>
                  <tr style="animation:fadeUp 0.2s ease both;animation-delay:<%=idx*0.03%>s">
                    <td>
                      <div class="flex items-center gap-1">
                        <% if(idx===0){ %><span data-tooltip="Highest scoring criterion">🥇</span>
                        <% } else if(idx===criteriaStats.length-1&&criteriaStats.length>1){ %>
                          <span data-tooltip="Lowest scoring — consider focusing here">⚠️</span>
                        <% } else { %><span class="criteria-num"><%=idx+1%></span><% } %>
                        <strong><%=s.name%></strong>
                      </div>
                    </td>
                    <td>
                      <div class="flex items-center gap-1">
                        <div class="progress-bar" style="width:90px;flex-shrink:0">
                          <div class="progress-fill" style="width:<%=(s.mean/5*100).toFixed(0)%>%;background:<%=c%>"></div>
                        </div>
                        <span style="color:<%=c%>;font-weight:700;min-width:34px"><%=s.mean.toFixed(2)%></span>
                      </div>
                    </td>
                    <td><%=s.median%></td>
                    <td><%=s.mode%></td>
                    <td><%=s.count%></td>
                    <td><span class="badge <%=scoreBadge(s.mean)%>"><%=scoreLabel(s.mean)%></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- WRITTEN FEEDBACK -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Written Feedback</div>
              <div class="card-subtitle">Anonymous student comments — identities are never stored</div>
            </div>
            <span class="badge badge-gray"><%=feedbacks.length%> comment<%=feedbacks.length!==1?'s':''%></span>
          </div>
          <% if(feedbacks.length===0){ %>
            <div class="empty-state" style="padding:2.5rem">
              <div class="empty-icon" style="font-size:2.25rem">💬</div>
              <h3>No written feedback</h3>
              <p>No students left written comments for this lecturer in the selected period.</p>
            </div>
          <% } else { %>
            <% feedbacks.forEach((f,i)=>{ %>
              <div style="
                background:var(--surface2);border:1px solid var(--border);
                border-left:3px solid var(--border-light);
                border-radius:var(--radius-sm);padding:1rem 1.125rem;
                margin-bottom:0.75rem;
                animation:fadeUp 0.25s ease both;animation-delay:<%=i*0.04%>s
              ">
                <div style="font-size:2rem;line-height:1;color:var(--border-light);font-family:var(--font-display);margin-bottom:0.25rem;user-select:none">"</div>
                <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.65;font-style:italic;margin-bottom:0.75rem">
                  <%=f.text%>
                </p>
                <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">
                  <% if(f.course){ %><span class="badge badge-blue"><%=f.course%></span><% } %>
                  <span style="font-size:0.7rem;color:var(--text-dim);margin-left:auto">
                    <%=new Date(f.date).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})%>
                  </span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

      <% } %>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>

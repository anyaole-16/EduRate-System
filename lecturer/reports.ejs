<%- include('../partials/header', { title: 'Evaluation Reports' }) %>

<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'reports' }) %>

  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Evaluation Reports' }) %>

    <div class="content-area">

      <%
        function scoreCol(v) {
          return v >= 4.5 ? '#0fb981' : v >= 3.5 ? '#2a6fdb' : v >= 2.5 ? '#f0a847' : '#f04a4a';
        }
        function scoreBadge(v) {
          return v >= 4.5 ? 'badge-green' : v >= 3.5 ? 'badge-blue' : v >= 2.5 ? 'badge-yellow' : 'badge-red';
        }
        function scoreLabel(v) {
          return v >= 4.5 ? 'Excellent' : v >= 3.5 ? 'Good' : v >= 2.5 ? 'Average' : 'Below Average';
        }
        const hasData = criteriaStats && criteriaStats.length > 0;
      %>

      <!-- ══════════════════════════════════════════════════════
           PAGE INTRO BANNER
      ══════════════════════════════════════════════════════ -->
      <div class="section-banner" style="margin-bottom:1.75rem">
        <div class="section-banner-icon">📈</div>
        <div>
          <h2>Evaluation Reports</h2>
          <p>
            Detailed statistical breakdown of your evaluation responses.
            Filter by semester, year, or course. All feedback is anonymous.
          </p>
        </div>
      </div>

      <!-- ══════════════════════════════════════════════════════
           FILTER BAR
      ══════════════════════════════════════════════════════ -->
      <div class="card" style="margin-bottom:1.5rem">
        <div class="card-header" style="margin-bottom:1rem">
          <div class="card-title">Filters</div>
          <% if (typeof filters !== 'undefined' && (filters.semester || filters.academicYear || filters.courseId)) { %>
            <div style="display:flex; align-items:center; gap:0.5rem">
              <span class="badge badge-yellow">Active filter</span>
              <a href="/lecturer/reports" class="btn btn-ghost btn-sm">✕ Clear</a>
            </div>
          <% } %>
        </div>
        <form action="/lecturer/reports" method="GET"
              class="flex gap-2" style="flex-wrap:wrap; align-items:flex-end"
              data-loading-text="Filtering…">

          <div class="form-group" style="margin-bottom:0; flex:1; min-width:130px">
            <label class="form-label">Semester</label>
            <select name="semester" class="form-control">
              <option value="">All Semesters</option>
              <option value="First"
                <%= typeof filters !== 'undefined' && filters.semester === 'First' ? 'selected' : '' %>>
                First
              </option>
              <option value="Second"
                <%= typeof filters !== 'undefined' && filters.semester === 'Second' ? 'selected' : '' %>>
                Second
              </option>
            </select>
          </div>

          <div class="form-group" style="margin-bottom:0; flex:1; min-width:140px">
            <label class="form-label">Academic Year</label>
            <input type="text" name="academicYear" class="form-control"
              placeholder="e.g. 2023/2024"
              value="<%= typeof filters !== 'undefined' ? (filters.academicYear || '') : '' %>">
          </div>

          <div class="form-group" style="margin-bottom:0; flex:2; min-width:180px">
            <label class="form-label">Course</label>
            <select name="courseId" class="form-control">
              <option value="">All My Courses</option>
              <% if (typeof courses !== 'undefined') { %>
                <% courses.forEach(c => { %>
                  <option value="<%= c._id %>"
                    <%= typeof filters !== 'undefined' && filters.courseId === String(c._id) ? 'selected' : '' %>>
                    <%= c.code %> — <%= c.title %>
                  </option>
                <% }) %>
              <% } %>
            </select>
          </div>

          <div style="display:flex; gap:0.5rem">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a href="/lecturer/reports" class="btn btn-secondary">Clear</a>
          </div>

        </form>
      </div>

      <!-- ══════════════════════════════════════════════════════
           EMPTY STATE
      ══════════════════════════════════════════════════════ -->
      <% if (!hasData) { %>
        <div class="card" style="padding:4rem; text-align:center">
          <div style="font-size:3rem; margin-bottom:1rem; opacity:0.3">🔍</div>
          <h3 style="margin-bottom:0.5rem">No data for this filter</h3>
          <p class="text-muted text-sm">
            Try adjusting the semester, academic year, or course filter above.
          </p>
          <a href="/lecturer/reports" class="btn btn-secondary" style="margin-top:1.25rem">
            Clear Filters
          </a>
        </div>

      <% } else { %>

      <!-- ══════════════════════════════════════════════════════
           SUMMARY STAT STRIP
      ══════════════════════════════════════════════════════ -->
      <div class="stats-grid" style="grid-template-columns:repeat(4,1fr); margin-bottom:1.5rem">

        <div class="stat-card">
          <div class="stat-icon" style="background:rgba(42,111,219,0.15); color:var(--accent2)">📬</div>
          <div class="stat-info">
            <div class="value"><%= totalResponses %></div>
            <div class="label">Total Responses</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon" style="background:rgba(15,185,129,0.15); color:var(--success)">📐</div>
          <div class="stat-info">
            <div class="value" style="color:<%= overallStats ? scoreCol(overallStats.mean) : 'inherit' %>">
              <%= overallStats ? overallStats.mean.toFixed(2) : '—' %>
            </div>
            <div class="label">Overall Mean</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon" style="background:rgba(139,92,246,0.15); color:#c4b5fd">📏</div>
          <div class="stat-info">
            <div class="value"><%= overallStats ? overallStats.median : '—' %></div>
            <div class="label">Overall Median</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon" style="background:rgba(240,168,71,0.15); color:var(--warning)">🎯</div>
          <div class="stat-info">
            <div class="value"><%= overallStats ? overallStats.mode : '—' %></div>
            <div class="label">Overall Mode</div>
          </div>
        </div>

      </div>

      <!-- ══════════════════════════════════════════════════════
           CRITERIA BREAKDOWN TABLE
      ══════════════════════════════════════════════════════ -->
      <div class="card" style="margin-bottom:1.5rem">
        <div class="card-header">
          <div>
            <div class="card-title">Criteria Breakdown</div>
            <div class="card-subtitle">
              Mean, median and mode per evaluation criterion — sorted by score descending
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:0.5rem">
            <input
              type="search"
              data-search-target="criteria-table"
              class="form-control"
              placeholder="Search criteria…"
              style="width:180px; font-size:0.8rem; padding:0.4rem 0.75rem"
              aria-label="Search criteria table"
            >
            <span class="badge badge-blue"><%= totalResponses %> responses</span>
          </div>
        </div>

        <div class="table-wrapper">
          <table id="criteria-table">
            <thead>
              <tr>
                <th>Criteria</th>
                <th>Category</th>
                <th style="min-width:160px">Mean Score</th>
                <th>Median</th>
                <th>Mode</th>
                <th>Responses</th>
                <th>Rating</th>
              </tr>
            </thead>
            <tbody>
              <%
                const sortedCriteria = criteriaStats.slice().sort((a,b) => b.mean - a.mean);
              %>
              <% sortedCriteria.forEach((s, idx) => { %>
                <%
                  const c     = scoreCol(s.mean);
                  const badge = scoreBadge(s.mean);
                  const lbl   = scoreLabel(s.mean);
                %>
                <tr>
                  <td>
                    <div style="display:flex; align-items:center; gap:0.6rem">
                      <% if (idx === 0) { %>
                        <span data-tooltip="Highest scoring criterion" style="font-size:0.9rem">🥇</span>
                      <% } else if (idx === sortedCriteria.length - 1 && sortedCriteria.length > 1) { %>
                        <span data-tooltip="Lowest scoring criterion — consider focusing here" style="font-size:0.9rem">⚠️</span>
                      <% } else { %>
                        <span class="criteria-num"><%= idx + 1 %></span>
                      <% } %>
                      <strong><%= s.name %></strong>
                    </div>
                  </td>
                  <td>
                    <span class="badge badge-purple"><%= s.category || '—' %></span>
                  </td>
                  <td>
                    <div class="flex items-center gap-1">
                      <div class="progress-bar" style="width:90px; flex-shrink:0">
                        <div class="progress-fill"
                             style="width:<%= (s.mean / 5 * 100).toFixed(0) %>%; background:<%= c %>">
                        </div>
                      </div>
                      <span style="color:<%= c %>; font-weight:700; min-width:32px">
                        <%= s.mean.toFixed(2) %>
                      </span>
                    </div>
                  </td>
                  <td><%= s.median.toFixed(1) %></td>
                  <td><%= s.mode %></td>
                  <td><%= s.count %></td>
                  <td>
                    <span class="badge <%= badge %>"><%= lbl %></span>
                  </td>
                </tr>
              <% }) %>
              <!-- Empty-search sentinel row -->
              <tr data-empty-row style="display:none">
                <td colspan="7" style="text-align:center; color:var(--text-muted); padding:2rem">
                  No criteria match your search.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ══════════════════════════════════════════════════════
           WRITTEN FEEDBACK
      ══════════════════════════════════════════════════════ -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Written Feedback</div>
            <div class="card-subtitle">
              Anonymous comments submitted by students — identities are not stored
            </div>
          </div>
          <span class="badge badge-gray">
            <%= feedbacks.length %> comment<%= feedbacks.length !== 1 ? 's' : '' %>
          </span>
        </div>

        <% if (feedbacks.length === 0) { %>
          <div class="empty-state" style="padding:2.5rem">
            <div class="empty-icon" style="font-size:2.5rem">💬</div>
            <h3>No written feedback</h3>
            <p>Students did not submit any written comments for this period.</p>
          </div>

        <% } else { %>

          <!-- Feedback sentiment summary strip -->
          <div style="
            display:flex; gap:1rem; flex-wrap:wrap;
            background:var(--surface2); border:1px solid var(--border);
            border-radius:var(--radius-sm); padding:0.875rem 1rem;
            margin-bottom:1.25rem; font-size:0.8rem; color:var(--text-muted)
          ">
            <span>🔒 All responses are anonymous</span>
            <span style="color:var(--border)">|</span>
            <span><%= feedbacks.length %> written comment<%= feedbacks.length !== 1 ? 's' : '' %> received</span>
            <span style="color:var(--border)">|</span>
            <span>Identities cannot be traced — submissions use one-way hashing</span>
          </div>

          <% feedbacks.forEach((f, i) => { %>
            <div style="
              background:var(--surface2);
              border:1px solid var(--border);
              border-left:3px solid var(--border-light);
              border-radius:var(--radius-sm);
              padding:1rem 1.125rem;
              margin-bottom:0.75rem;
              animation: fadeUp 0.3s ease both;
              animation-delay:<%= i * 0.04 %>s;
            ">
              <!-- Quotation mark decoration -->
              <div style="
                font-size:2rem; line-height:1; color:var(--border-light);
                font-family:var(--font-display); margin-bottom:0.25rem; user-select:none
              ">"</div>

              <p style="
                font-size:0.875rem;
                color:var(--text-muted);
                line-height:1.65;
                margin-bottom:0.75rem;
                font-style:italic;
              ">
                <%= f.text %>
              </p>

              <!-- Meta row -->
              <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap">
                <% if (f.course) { %>
                  <span class="badge badge-blue"><%= f.course %></span>
                <% } %>
                <% if (f.semester) { %>
                  <span class="badge badge-gray"><%= f.semester %> Sem</span>
                <% } %>
                <span style="font-size:0.7rem; color:var(--text-dim); margin-left:auto">
                  <%= new Date(f.date).toLocaleDateString('en-GB', {
                    day: 'numeric', month: 'short', year: 'numeric'
                  }) %>
                </span>
              </div>
            </div>
          <% }) %>

        <% } %> <!-- /feedbacks -->

      </div><!-- /written feedback card -->

      <% } %> <!-- /hasData -->

    </div><!-- /content-area -->
  </main>
</div>

<%- include('../partials/footer') %>

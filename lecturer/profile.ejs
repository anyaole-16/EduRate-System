<%- include('../partials/header', { title: 'My Profile' }) %>

<div class="app-shell">
  <%- include('../partials/sidebar', { user, activeNav: 'profile' }) %>

  <main class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'My Profile' }) %>

    <div class="content-area">

      <!-- ══════════════════════════════════════════════════════
           PAGE INTRO BANNER
      ══════════════════════════════════════════════════════ -->
      <div class="section-banner" style="margin-bottom:1.75rem">
        <div class="section-banner-icon">👤</div>
        <div>
          <h2>Account Details</h2>
          <p>
            Your institutional information is managed by the administrator.
            You can update your password below.
          </p>
        </div>
      </div>

      <div class="grid-2" style="align-items:start">

        <!-- ══════════════════════════════════════════════════════
             PROFILE INFO CARD
        ══════════════════════════════════════════════════════ -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">Account Information</div>
            <span class="badge badge-green">Lecturer</span>
          </div>

          <!-- Avatar + identity block -->
          <div style="
            display:flex; align-items:center; gap:1.25rem;
            margin-bottom:1.5rem; padding-bottom:1.5rem;
            border-bottom:1px solid var(--border);
          ">
            <div class="avatar-lg avatar-green">
              <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2) %>
            </div>
            <div>
              <div style="font-weight:700; font-size:1.05rem; margin-bottom:0.2rem">
                <%= user.fullName %>
              </div>
              <div class="text-muted text-sm" style="margin-bottom:0.4rem">
                <%= user.email %>
              </div>
              <div style="display:flex; gap:0.4rem; flex-wrap:wrap">
                <span class="badge badge-green">Lecturer</span>
                <% if (user.isActive) { %>
                  <span class="badge badge-blue">Active</span>
                <% } else { %>
                  <span class="badge badge-red">Inactive</span>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Read-only institutional fields -->
          <div class="form-group">
            <label class="form-label">Full Name</label>
            <input type="text" class="form-control"
              value="<%= user.fullName %>" readonly
              data-tooltip="Contact your administrator to update this field">
          </div>

          <div class="form-group">
            <label class="form-label">Institutional Email</label>
            <input type="email" class="form-control"
              value="<%= user.email %>" readonly
              data-tooltip="Your email cannot be changed — contact admin">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Department</label>
              <input type="text" class="form-control"
                value="<%= user.department || '—' %>" readonly>
            </div>
            <div class="form-group">
              <label class="form-label">School / Faculty</label>
              <input type="text" class="form-control"
                value="<%= user.school || '—' %>" readonly>
            </div>
          </div>

          <div class="form-group" style="margin-bottom:0">
            <label class="form-label">Member Since</label>
            <input type="text" class="form-control"
              value="<%= new Date(user.createdAt).toLocaleDateString('en-GB', {
                day: 'numeric', month: 'long', year: 'numeric'
              }) %>" readonly>
          </div>

          <div class="divider"></div>

          <!-- Courses taught (read-only snapshot) -->
          <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
            <div>
              <div class="form-label" style="margin-bottom:0.6rem">Courses Assigned</div>
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem">
                <% courses.forEach(c => { %>
                  <span class="badge badge-purple"
                        data-tooltip="<%= c.title %> — <%= c.semester %> Sem <%= c.academicYear %>">
                    <%= c.code %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% } else { %>
            <p class="text-muted text-sm">No courses currently assigned.</p>
          <% } %>
        </div>

        <!-- ══════════════════════════════════════════════════════
             CHANGE PASSWORD CARD
        ══════════════════════════════════════════════════════ -->
        <div>

          <div class="card" style="margin-bottom:1.25rem">
            <div class="card-header">
              <div>
                <div class="card-title">Change Password</div>
                <div class="card-subtitle">
                  Passwords are hashed with bcrypt — never stored in plain text
                </div>
              </div>
              <span style="font-size:1.25rem" aria-hidden="true">🔒</span>
            </div>

            <!-- Flash alerts from controller redirect -->
            <% if (typeof successMsg !== 'undefined' && successMsg) { %>
              <div class="alert alert-success" style="margin-bottom:1.25rem"
                   data-autodismiss="5000">
                ✓ <%= successMsg %>
              </div>
            <% } %>
            <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
              <div class="alert alert-danger" style="margin-bottom:1.25rem">
                ⚠ <%= errorMsg %>
              </div>
            <% } %>

            <form action="/lecturer/profile/password" method="POST"
                  id="pwd-form"
                  data-loading-text="Updating…">

              <div class="form-group">
                <label class="form-label" for="currentPassword">Current Password</label>
                <div class="password-field">
                  <input
                    type="password"
                    id="currentPassword"
                    name="currentPassword"
                    class="form-control"
                    placeholder="Enter your current password"
                    required
                    autocomplete="current-password"
                  >
                  <button type="button" class="password-toggle" aria-label="Show/hide password">👁</button>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="newPassword">New Password</label>
                <div class="password-field">
                  <input
                    type="password"
                    id="newPassword"
                    name="newPassword"
                    class="form-control"
                    placeholder="Minimum 6 characters"
                    required
                    minlength="6"
                    autocomplete="new-password"
                  >
                  <button type="button" class="password-toggle" aria-label="Show/hide password">👁</button>
                </div>
                <!-- Password strength meter -->
                <div style="margin-top:0.5rem">
                  <div class="progress-bar" style="height:4px">
                    <div id="pwd-strength-bar"
                         class="progress-fill"
                         style="width:0%; transition:width 0.3s ease, background 0.3s ease">
                    </div>
                  </div>
                  <span id="pwd-strength-label" class="form-hint">Enter a new password</span>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="confirmPassword">Confirm New Password</label>
                <div class="password-field">
                  <input
                    type="password"
                    id="confirmPassword"
                    name="confirmPassword"
                    class="form-control"
                    placeholder="Repeat your new password"
                    required
                    autocomplete="new-password"
                  >
                  <button type="button" class="password-toggle" aria-label="Show/hide password">👁</button>
                </div>
                <span id="confirm-match-hint" class="form-hint"></span>
              </div>

              <div class="divider"></div>
              <button type="submit" class="btn btn-primary btn-block">
                Update Password
              </button>

            </form>
          </div>

          <!-- ── Security info panel ── -->
          <div class="card">
            <div class="card-header" style="margin-bottom:0.75rem">
              <div class="card-title" style="font-size:0.875rem">Security Info</div>
            </div>
            <ul style="
              list-style:none;
              display:flex; flex-direction:column; gap:0.5rem;
              font-size:0.8rem; color:var(--text-muted)
            ">
              <li style="display:flex; align-items:flex-start; gap:0.6rem">
                <span>🔐</span>
                <span>Passwords are hashed with bcrypt and never stored in plain text</span>
              </li>
              <li style="display:flex; align-items:flex-start; gap:0.6rem">
                <span>📧</span>
                <span>
                  Last login:&nbsp;
                  <strong style="color:var(--text)">
                    <%= user.lastLogin
                        ? new Date(user.lastLogin).toLocaleDateString('en-GB', {
                            day: 'numeric', month: 'short', year: 'numeric'
                          })
                        : 'Unknown'
                    %>
                  </strong>
                </span>
              </li>
              <li style="display:flex; align-items:flex-start; gap:0.6rem">
                <span>🔑</span>
                <span>
                  Forgot your password?
                  <a href="/auth/forgot-password">Reset via email</a>
                </span>
              </li>
            </ul>
          </div>

        </div><!-- /right column -->
      </div><!-- /grid-2 -->
    </div><!-- /content-area -->
  </main>
</div>

<%- include('../partials/footer', { extraJs: ['profile.js'] }) %>

<%- include('partials/header', { title: 'Welcome', extraCss: 'auth.css' }) %>

<div style="min-height:100vh; background:var(--bg); display:flex; flex-direction:column">

  <!-- ═══════════════════════════════════════════════
       NAVIGATION BAR
  ═══════════════════════════════════════════════ -->
  <nav style="
    display:flex; align-items:center; justify-content:space-between;
    padding:1.25rem 3rem;
    border-bottom:1px solid var(--border);
    background:var(--surface);
    position:sticky; top:0; z-index:50;
  ">
    <a href="/" class="logo-mark">
      <div class="logo-icon">📊</div>
      <div class="logo-text">Edu<span>Rate</span></div>
    </a>
    <div style="display:flex; gap:0.75rem; align-items:center">
      <a href="/auth/login"       class="btn btn-secondary btn-sm">Login</a>
      <a href="/auth/admin-login" class="btn btn-primary   btn-sm">Admin Portal</a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════════════ -->
  <section style="
    flex:1;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    text-align:center;
    padding:5rem 2rem 3rem;
    position:relative; overflow:hidden;
  ">
    <!-- Background grid -->
    <div style="
      position:absolute; inset:0;
      background-image: radial-gradient(circle, rgba(42,111,219,0.1) 1px, transparent 1px);
      background-size:36px 36px;
      pointer-events:none;
    "></div>
    <!-- Glow -->
    <div style="
      position:absolute; top:-200px; left:50%; transform:translateX(-50%);
      width:800px; height:800px;
      background:radial-gradient(circle, rgba(42,111,219,0.1) 0%, transparent 65%);
      pointer-events:none;
    "></div>

    <!-- Content -->
    <div style="position:relative; max-width:720px">

      <div style="
        display:inline-flex; align-items:center; gap:0.5rem;
        background:rgba(42,111,219,0.12); border:1px solid rgba(42,111,219,0.25);
        border-radius:99px; padding:0.375rem 1rem;
        font-size:0.78rem; font-weight:600; color:var(--accent2);
        margin-bottom:1.75rem; letter-spacing:0.3px;
      ">
        📊 Institutional Evaluation System
      </div>

      <h1 style="
        font-family:var(--font-display);
        font-size:clamp(2.25rem, 5vw, 3.5rem);
        font-weight:800;
        line-height:1.1;
        letter-spacing:-1.5px;
        margin-bottom:1.25rem;
      ">
        Better Feedback.<br>
        <span style="color:var(--accent2)">Better Teaching.</span>
      </h1>

      <p style="
        font-size:1.05rem; color:var(--text-muted);
        line-height:1.7; max-width:520px; margin:0 auto 2.5rem;
      ">
        EduRate helps students share anonymous evaluations of their lecturers,
        giving educators meaningful insights to improve their teaching — every semester.
      </p>

      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap">
        <a href="/auth/login" class="btn btn-primary btn-lg">
          Get Started →
        </a>
        <a href="/auth/register" class="btn btn-secondary btn-lg">
          Register as Student
        </a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURE CARDS
  ═══════════════════════════════════════════════ -->
  <section style="padding:4rem 3rem; background:var(--surface); border-top:1px solid var(--border)">

    <div style="text-align:center; margin-bottom:3rem">
      <h2 style="font-size:1.75rem; font-weight:800; letter-spacing:-0.5px; margin-bottom:0.5rem">
        Built for every role
      </h2>
      <p style="color:var(--text-muted); font-size:0.95rem">
        One platform, three dashboards — each designed for its user.
      </p>
    </div>

    <div style="
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(240px, 1fr));
      gap:1.5rem;
      max-width:960px; margin:0 auto;
    ">

      <!-- Student -->
      <div style="
        background:var(--surface2); border:1px solid var(--border);
        border-radius:var(--radius); padding:1.75rem;
        transition:border-color 0.2s, transform 0.2s;
      "
        onmouseover="this.style.borderColor='var(--accent)';this.style.transform='translateY(-3px)'"
        onmouseout="this.style.borderColor='var(--border)';this.style.transform=''"
      >
        <div style="font-size:2rem; margin-bottom:1rem">🎓</div>
        <h3 style="font-size:1rem; font-weight:700; margin-bottom:0.5rem">Students</h3>
        <p style="font-size:0.85rem; color:var(--text-muted); line-height:1.6">
          Rate your lecturers on clear criteria using a simple 1–5 scale.
          All responses are fully anonymous — your identity is never stored.
        </p>
        <a href="/auth/login" style="
          display:inline-block; margin-top:1.25rem;
          font-size:0.8rem; font-weight:600; color:var(--accent2);
        ">Sign in as student →</a>
      </div>

      <!-- Lecturer -->
      <div style="
        background:var(--surface2); border:1px solid var(--border);
        border-radius:var(--radius); padding:1.75rem;
        transition:border-color 0.2s, transform 0.2s;
      "
        onmouseover="this.style.borderColor='var(--success)';this.style.transform='translateY(-3px)'"
        onmouseout="this.style.borderColor='var(--border)';this.style.transform=''"
      >
        <div style="font-size:2rem; margin-bottom:1rem">👨‍🏫</div>
        <h3 style="font-size:1rem; font-weight:700; margin-bottom:0.5rem">Lecturers</h3>
        <p style="font-size:0.85rem; color:var(--text-muted); line-height:1.6">
          View your own evaluation results — charts, statistics, and written feedback.
          Filter by semester, year, or course to track your progress over time.
        </p>
        <a href="/auth/login" style="
          display:inline-block; margin-top:1.25rem;
          font-size:0.8rem; font-weight:600; color:var(--success);
        ">Sign in as lecturer →</a>
      </div>

      <!-- Admin -->
      <div style="
        background:var(--surface2); border:1px solid var(--border);
        border-radius:var(--radius); padding:1.75rem;
        transition:border-color 0.2s, transform 0.2s;
      "
        onmouseover="this.style.borderColor='var(--warning)';this.style.transform='translateY(-3px)'"
        onmouseout="this.style.borderColor='var(--border)';this.style.transform=''"
      >
        <div style="font-size:2rem; margin-bottom:1rem">⚙️</div>
        <h3 style="font-size:1rem; font-weight:700; margin-bottom:0.5rem">Administrators</h3>
        <p style="font-size:0.85rem; color:var(--text-muted); line-height:1.6">
          Manage users, courses, and evaluation periods. View institution-wide
          analytics and export reports as PDF or CSV for performance reviews.
        </p>
        <a href="/auth/admin-login" style="
          display:inline-block; margin-top:1.25rem;
          font-size:0.8rem; font-weight:600; color:var(--warning);
        ">Admin portal →</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       STATS STRIP
  ═══════════════════════════════════════════════ -->
  <section style="
    padding:2.5rem 3rem;
    display:flex; justify-content:center; gap:4rem; flex-wrap:wrap;
    border-top:1px solid var(--border);
  ">
    <div style="text-align:center">
      <div style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:var(--accent2)">
        100%
      </div>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">Anonymous responses</div>
    </div>
    <div style="text-align:center">
      <div style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:var(--success)">
        7
      </div>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">Evaluation criteria</div>
    </div>
    <div style="text-align:center">
      <div style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:var(--warning)">
        3
      </div>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">Role-based dashboards</div>
    </div>
    <div style="text-align:center">
      <div style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:#c4b5fd">
        PDF
      </div>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem">& CSV export ready</div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════ -->
  <footer style="
    padding:1.25rem 3rem;
    border-top:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
    flex-wrap:wrap; gap:0.75rem;
    font-size:0.78rem; color:var(--text-dim);
  ">
    <span>© <%= new Date().getFullYear() %> EduRate. All rights reserved.</span>
    <div style="display:flex; gap:1.25rem">
      <a href="/auth/login"       style="color:var(--text-dim)">Student Login</a>
      <a href="/auth/admin-login" style="color:var(--text-dim)">Admin</a>
      <a href="/auth/register"    style="color:var(--text-dim)">Register</a>
    </div>
  </footer>

</div>

<%- include('partials/footer') %>
